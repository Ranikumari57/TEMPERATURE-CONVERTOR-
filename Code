#include <LiquidCrystal.h>

// LCD Pins: RS, E, D4, D5, D6, D7
LiquidCrystal lcd(12, 11, 5, 4, 3, 2);

int sensorPin = A0;
float voltage, tempC, tempF;

void setup() {
  lcd.begin(16, 2);
  lcd.print("Temperature");
  delay(2000);
  lcd.clear();
}

void loop() {
  voltage = analogRead(sensorPin) * (5.0 / 1023.0);
  tempC = voltage * 100.0;
  tempF = (tempC * 9.0 / 5.0) + 32.0;

  lcd.setCursor(0, 0);
  lcd.print("C:");
  lcd.print(tempC);
  lcd.print((char)223);
  lcd.print("C");

  lcd.setCursor(0, 1);
  lcd.print("F:");
  lcd.print(tempF);
  lcd.print((char)223);
  lcd.print("F");

  delay(1000);
}
